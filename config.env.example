# config.env — OpenStack MCP 배포 설정. config.env로 복사 후 값만 수정.
# 호출자 자격증명(application credential)은 여기 넣지 않는다 — 클라가 요청 헤더로 전달.
MCP_PORT=8001
MCP_NODE_NAME=
OS_AUTH_URL=http://<keystone-host>:5000/v3
# 마운트할 도메인/티어 (비우면 전체)
OSMCP_DOMAINS=
OSMCP_TIERS=
# Kolla 로그 경로 (log_tail용; 호스트에서 ro 마운트)
KOLLA_LOG_DIR=/var/log/kolla
